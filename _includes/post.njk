---
layout: base.njk
---
<article class="post">
  <header class="post-header">
    <h2 class="post-title">{{ title }}</h2>
    <p class="post-meta">
      <time datetime="{{ page.date | htmlDate }}">{{ page.date | readableDate }}</time>
      {% set displayTags = tags | reject("equalto", "posts") %}
      {% if displayTags | length %}
        &middot;
        {% for tag in displayTags %}<a class="tag" href="/tag/{{ tag | tagSlug }}/">{{ tag }}</a>{% if not loop.last %} {% endif %}{% endfor %}
      {% endif %}
    </p>
  </header>
  <div class="post-body">
    {{ content | safe }}
  </div>
</article>
