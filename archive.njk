---
layout: base.njk
title: archive
permalink: /archive/
---
<header class="archive-header">
  <h2 class="archive-title">archive</h2>
  <p class="archive-meta">{{ collections.posts | length }} posts</p>
</header>

{% for group in collections.postsByYear %}
  <h3 class="archive-year">{{ group.year }}</h3>
  <ul class="archive-list">
  {% for post in group.posts %}
    <li class="archive-item">
      <time datetime="{{ post.date | htmlDate }}">{{ post.date | monthDay }}</time>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </li>
  {% endfor %}
  </ul>
{% endfor %}
